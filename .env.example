# ===================================================
# LinkedBridge — Environment Variables
# ===================================================
# Copy this file to .env and fill in the values.
# NEVER commit the .env file to version control.
# ===================================================

# ---------------------------------------------------
# Database (Supabase / PostgreSQL)
# ---------------------------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# ---------------------------------------------------
# Encryption (AES-256-GCM)
# ---------------------------------------------------
# MUST be exactly 32 bytes (256 bits) — the application will refuse to start otherwise (Fail-Fast).
#
# Generate with one of:
#   openssl rand -base64 32
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#
# The value MUST be a valid Base64 string that decodes to exactly 32 bytes.
ENCRYPTION_MASTER_KEY="your-base64-encoded-32-byte-key-here"

# ---------------------------------------------------
# Application
# ---------------------------------------------------
NODE_ENV="development"
PORT=3333

# ---------------------------------------------------
# LinkedIn OAuth 2.0 (for future tasks)
# ---------------------------------------------------
# LINKEDIN_CLIENT_ID=""
# LINKEDIN_CLIENT_SECRET=""
# LINKEDIN_REDIRECT_URI=""
